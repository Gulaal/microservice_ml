# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/
.env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.ropeproject

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# Project-specific: trained models (large files)
**/models/*.pth
**/models/*.pt
**/models/*.h5
**/models/*.onnx

# Data downloaded (MNIST etc.)
**/data/
**/MNIST/
**/*.gz
**/*.idx3-ubyte
**/*.idx1-ubyte

# Logs and databases
*.log
*.sql
*.sqlite3

# Environment variables
.env
.env.local
*.env

# Docker
**/.dockerignore
docker-compose.override.yml

# OS specific
.DS_Store
Thumbs.db
desktop.ini

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# FastAPI / uvicorn temp files
uvicorn.log

# Exclude large files from accidental commits
*.zip
*.tar.gz
*.rar